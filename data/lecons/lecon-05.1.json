  "cours": [
    {
      "type": "texte",
      "contenu": "Le pluriel en luxembourgeois change selon le genre du nom. Il utilise zwee (M/N) ou zwou (F)."
    },
    {
      "type": "regle",
      "titre": "Zwee vs Zwou",
      "lignes": [
        "Masculin + Neutre → <b>zwee</b> : zwee Fligeren, zwee Bicher",
        "Féminin → <b>zwou</b> : zwou Fläschen, zwou Tasen",
        "⚠️ zwee = 2 (zwee Persounen = 2 personnes)"
      ]
    },
    {
      "type": "vocab",
      "titre": "Formation du pluriel — Exemples",
      "items": [
        [
          "e Fliger → zwee Fligeren",
          "un avion → deux avions (M)"
        ],
        [
          "eng Fläsch → zwou Fläschen",
          "une bouteille → deux bouteilles (F)"
        ],
        [
          "e Buch → zwee Bicher",
          "un livre → deux livres (N)"
        ],
        [
          "eng Taass → zwou Tasen",
          "une tasse → deux tasses (F)"
        ],
        [
          "e Stull → zwee Stüll",
          "une table → deux tables (M)"
        ],
        [
          "eng Planz → zwou Planzen",
          "une plante → deux plantes (F)"
        ]
      ]
    },
    {
      "type": "dialogue",
      "titre": "Exemples de phrases",
      "echanges": [
        [
          "Huess du zwee Fligeren?",
          "As-tu deux avions ?"
        ],
        [
          "Nee, ech hunn zwee Vëloen.",
          "Non, j'ai deux vélos."
        ],
        [
          "Wéi vill Fläschen sinn dat?",
          "Combien de bouteilles y a-t-il ?"
        ],
        [
          "Dat sinn zwou Fläschen.",
          "Ce sont deux bouteilles."
        ]
      ]
    }
  ]
