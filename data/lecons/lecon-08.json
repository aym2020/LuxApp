  "cours": [
    {
      "type": "texte",
      "contenu": "La nationalité a une forme masculine et une forme féminine. On utilise l'article indéfini devant."
    },
    {
      "type": "regle",
      "titre": "Formation",
      "lignes": [
        "Masculin → nationalité seule : Portugis, Spuenier, Englänner, Fransous.",
        "Féminin → souvent nationalité + -in : Portugisin, Spuenierin, Englännerin, Fransousin.",
        "Avec une négation, on utilise <b>kee</b> au masculin et <b>keng</b> au féminin : kee Spuenier, keng Italienerin."
      ]
    },
