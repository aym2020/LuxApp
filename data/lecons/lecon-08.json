  "cours": [
    {
      "type": "texte",
      "contenu": "La nationalité a une forme masculine et une forme féminine. On utilise l'article indéfini devant."
    },
    {
      "type": "regle",
      "titre": "Formation",
      "lignes": [
        "Masculin → <b>e</b> / <b>en</b> + nationalité (e Portugis, en Engländer)",
        "Féminin → <b>eng</b> + nationalité + souvent terminaison <b>-in</b> (eng Portugisin)",
        "Négation : <b>kee/keen</b> (M), <b>keng</b> (F)"
      ]
    },
    {
      "type": "regle",
      "titre": "Poser une question sur la nationalité",
      "lignes": [
        "Wat ass seng Nationalitéit? = Quelle est sa nationalité ?",
        "Wat ass hir Nationalitéit? = Quelle est sa nationalité ?",
        "Ass hien ...? = Est-il ... ?",
        "Ass si ...? = Est-elle ... ?",
        "Jo, hien/si ass ... = Oui, il/elle est ...",
        "Nee, hien ass kee ... / si ass keng ... = Non, il/elle n'est pas ..."
      ]
    },
