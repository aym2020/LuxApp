    {
      "type": "texte",
      "contenu": "Chaque nationalité a une forme <b>masculine</b> et une forme <b>féminine</b>. La leçon consiste surtout à passer de l'une à l'autre."
    },
    {
      "type": "callout",
      "variant": "retenir",
      "titre": "Former le féminin : + -in",
      "lignes": [
        "Dans la plupart des cas, le féminin = masculin + <b>-in</b>.",
        "<b>Portugis → Portugisin</b>, <b>Spuenier → Spuenierin</b>, <b>Japaner → Japanerin</b>."
      ]
    },
