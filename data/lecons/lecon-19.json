    {
      "type": "callout",
      "variant": "attention",
      "titre": "La règle d'accord",
      "lignes": [
        "Le possessif s'accorde avec le nom POSSÉDÉ, jamais avec le possesseur.",
        "Une femme parle de son mari → hire Mann (Mann est masculin).",
        "Un homme parle de sa mère → seng Mamm (Mamm est féminin).",
        "Le (n) final suit la règle d'Eifel : on le garde devant a, e, i, o, u, d, t, n, z, h, sinon il tombe.",
        "Ex. : säin Numm (devant N) mais säi Papp (devant P)."
      ]
    },
