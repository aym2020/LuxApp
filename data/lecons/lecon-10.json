  "cours": [
    {
      "type": "texte",
      "contenu": "Pour dire où l'on habite, on utilise <b>wunnen</b> + une préposition. Cette préposition <b>dépend du type de lieu</b> : pays, ville, quartier ou expression fixe."
    },
    {
      "type": "callout",
      "variant": "retenir",
      "titre": "La logique générale",
      "lignes": [
        "Pays sans article → <b>a / an</b> : a Frankräich, an Däitschland.",
        "Pays féminins → <b>an der</b> : an der Belsch, an der Schwäiz.",
        "Villes → <b>zu</b> : zu Metz, zu Paräis, zu Esch.",
        "Quartiers ou lieux particuliers → souvent <b>um / am</b> : um Kirchberg, am Gronn.",
        "Luxembourg est une exception utile à mémoriser : <b>zu Lëtzebuerg</b>."
      ]
    },
    {
      "type": "tableau",
      "titre": "Choisir la bonne préposition",
      "entetes": [
        "Type de lieu",
