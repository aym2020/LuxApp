        "Exemples"
      ],
      "lignes": [
        [
          "Pays sans article",
          "a / an + pays",
          "a Frankräich · an Däitschland"
        ],
        [
          "Pays féminin",
          "an der + pays",
          "an der Belsch · an der Schwäiz"
        ],
        [
          "Luxembourg",
