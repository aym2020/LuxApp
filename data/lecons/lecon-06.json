        ],
        [
          "eng Fläsch → zwou Fläschen",
          "une bouteille → deux bouteilles (F)"
        ],
        [
          "e Buch → zwee Bicher",
          "un livre → deux livres (N)"
        ],
        [
          "eng Taass → zwou Tasen",
          "une tasse → deux tasses (F)"
        ],
        [
          "e Stull → zwee Still",
          "une chaise → deux chaises (M)"
        ],
        [
          "eng Planz → zwou Planzen",
          "une plante → deux plantes (F)"
        ]
      ]
    },
    {
      "type": "dialogue",
      "titre": "Exemples de phrases",
      "echanges": [
