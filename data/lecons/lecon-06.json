      "type": "regle",
      "titre": "Zwee vs Zwou",
      "lignes": [
        "Masculin + Neutre → <b>zwee</b> : zwee Fligeren, zwee Bicher",
        "Féminin → <b>zwou</b> : zwou Fläschen, zwou Tasen",
        "⚠️ zwee = 2 (zwee Persounen = 2 personnes)"
      ]
    },
