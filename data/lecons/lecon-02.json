    {
      "type": "callout",
      "variant": "astuce",
      "titre": "UNITEDZOHA : la règle du -n",
      "lignes": [
        "On garde le <b>-n</b> (<b>en</b> / <b>keen</b>) seulement si le mot suivant commence par une <b>voyelle</b> ou par <b>n, d, t, z, h</b>.",
        "Moyen mnémotechnique : <b>U·N·I·T·E·D·Z·O·H·A</b>.",
        "Avec -n : <b>en</b> Auto, <b>en</b> Dësch, <b>en</b> Telefon, <b>en</b> Haus.",
        "Sans -n : <b>e</b> Bus, <b>e</b> Computer, <b>e</b> Stull, <b>e</b> Glas."
      ]
    },
